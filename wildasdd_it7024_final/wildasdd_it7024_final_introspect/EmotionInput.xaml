<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="wildasdd_it7024_final_introspect.EmotionInput"
             Title="EmotionInput">
    <Grid
        RowDefinitions="160,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,*"
        BackgroundColor="CornflowerBlue"
        RowSpacing="10"
        >
        <Label
            Grid.Row="0"
            Text="Self-Awareness of Emotions"
            TextColor="White"
            FontAttributes="Bold"
            FontSize="40"
            HorizontalTextAlignment="Center"
            VerticalOptions="Center" 
            HorizontalOptions="Center"
            >
        </Label>
        <Label
            Grid.Row="1"
            Text="I can usually identify what I am feeling before I react to a situtaion"
            TextColor="White"
            FontAttributes="Bold"
            Margin="10"
            >
        </Label>
        <Grid
            Grid.Row="2"
            ColumnDefinitions="*,*,*,*,*"
            RadioButtonGroup.GroupName="Emotion1">
            <RadioButton TextColor="White" FontSize="10" Grid.Column ="0" x:Name="Emotion1_StrongD" Content="Strongly Disagree"/>
            <RadioButton TextColor="White" FontSize="10" Grid.Column ="1" x:Name="Emotion1_SomewhatD" Content="Somewhat Disagree"/>
            <RadioButton TextColor="White" FontSize="10" Grid.Column ="2" x:Name="Emotion1_Neutral" Content="Neutral"/>
            <RadioButton TextColor="White" FontSize="10" Grid.Column ="3" x:Name="Emotion1_SomewhatA" Content="Somewhat Agree"/>
            <RadioButton TextColor="White" FontSize="10" Grid.Column ="4" x:Name="Emotion1_StrongA" Content="Strongly Agree"/>
        </Grid>
        <Label
            Grid.Row="3"
            Text="I understand why certain situtaions trigger stronger emotional responses than others."
            TextColor="White"
            FontAttributes="Bold"
            Margin="10"
            >
        </Label>
        <Grid
         Grid.Row="4"
             ColumnDefinitions="*,*,*,*,*">
            <RadioButton TextColor="White" FontSize="10" Grid.Column ="0" x:Name="Emotion2_StrongD" Content="Strongly Disagree"/>
            <RadioButton TextColor="White" FontSize="10" Grid.Column ="1" x:Name="Emotion2_SomewhatD" Content="Somewhat Disagree"/>
            <RadioButton TextColor="White" FontSize="10" Grid.Column ="2" x:Name="Emotion2_Neutral" Content="Neutral"/>
            <RadioButton TextColor="White" FontSize="10" Grid.Column ="3" x:Name="Emotion2_SomewhatA" Content="Somewhat Agree"/>
            <RadioButton TextColor="White" FontSize="10" Grid.Column ="4" x:Name="Emotion2_StrongA" Content="Strongly Agree"/>
        </Grid>
        <Label
            Grid.Row="5"
            Text="I am aware of how my mood effects the way I interpret events around me."
            TextColor="White"
            FontAttributes="Bold"
            Margin="10"
    >
        </Label>
        <Grid
            Grid.Row="6"
            ColumnDefinitions="*,*,*,*,*">
            <RadioButton TextColor="White" FontSize="10" Grid.Column ="0" x:Name="Emotion3_StrongD" Content="Strongly Disagree"/>
            <RadioButton TextColor="White"  FontSize="10" Grid.Column ="1" x:Name="Emotion3_SomewhatD" Content="Somewhat Disagree"/>
            <RadioButton TextColor="White" FontSize="10" Grid.Column ="2" x:Name="Emotion3_Neutral" Content="Neutral"/>
            <RadioButton TextColor="White" FontSize="10" Grid.Column ="3" x:Name="Emotion3_SomewhatA" Content="Somewhat Agree"/>
            <RadioButton TextColor="White" FontSize="10" Grid.Column ="4" x:Name="Emotion3_StrongA" Content="Strongly Agree"/>
        </Grid>
        <Label
               Grid.Row="7"
               Text="I can distinguish between what I am feeling and why I am feeling it."
               TextColor="White"
               FontAttributes="Bold"
               Margin="10"
           >
        </Label>
        <Grid
            Grid.Row="8"
            ColumnDefinitions="*,*,*,*,*">
            <RadioButton TextColor="White" FontSize="10" Grid.Column ="0" x:Name="Emotion4_StrongD" Content="Strongly Disagree"/>
            <RadioButton TextColor="White" FontSize="10" Grid.Column ="1" x:Name="Emotion4_SomewhatD" Content="Somewhat Disagree"/>
            <RadioButton TextColor="White" FontSize="10" Grid.Column ="2" x:Name="Emotion4_Neutral" Content="Neutral"/>
            <RadioButton TextColor="White" FontSize="10" Grid.Column ="3" x:Name="Emotion4_SomewhatA" Content="Somewhat Agree"/>
            <RadioButton TextColor="White" FontSize="10" Grid.Column ="4" x:Name="Emotion4_StrongA" Content="Strongly Agree"/>
        </Grid>
        <Grid
            ColumnDefinitions="*,*"
            Grid.Row="9"
            Padding="3"
            ColumnSpacing="8">
            <Button
                Grid.Column="0"
                Text="Back"
                FontAttributes="Bold"
                BackgroundColor="DarkBlue"
                TextColor="White"
                HeightRequest="75"
                Clicked="Emotion_Home_Clicked">
            </Button>
            <Button
                Grid.Column="1"
                Text="Self Reflection Input"
                FontAttributes="Bold"
                BackgroundColor="DarkBlue"
                TextColor="White"
                HeightRequest="75"
                Clicked="Self_Clicked"> 
            </Button>
        
        </Grid>
    </Grid>
</ContentPage>
<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="wildasdd_it7024_final_introspect.Submission"
             Title="Submission">
    <Grid
        RowDefinitions="225,200,*"
        RowSpacing="10"
        BackgroundColor="CornflowerBlue"
        >
        <Label 
            Grid.Row="0"
            Margin="10"
            Text="Introspection Score:"
            FontSize="25"
            FontAttributes="Bold"
            HorizontalTextAlignment="Center"
            VerticalOptions="Center" 
            HorizontalOptions="Center"
            TextColor="White">
        </Label>
        <Label 
            Grid.Row="1"
            x:Name="LblResults"
            FontSize="40"
            TextColor="Blue"
            VerticalOptions="Center" 
            HorizontalOptions="Center" />
        <Button
             Grid.Row="2"
             Text="Home"
             TextColor="White"
             BackgroundColor="Black"
             HeightRequest="75"
             Clicked="Submit_Home_Clicked">   
        </Button>
    </Grid>
</ContentPage>
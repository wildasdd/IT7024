<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="wildasdd_mod10_contact_list.Views.ContactDetail"
             xmlns:vm="clr-namespace:wildasdd_mod10_contact_list.Models.ViewModels"
             x:DataType="vm:ContactDetailViewModel">
    <TableView Intent="Data">
        <TableRoot>
            <TableSection Title="Contact Detail">
                <TextCell Text="Name" Detail="{Binding Contact.ContactName}"/>
                <TextCell Text="Email" Detail="{Binding Contact.ContactEmail}"/>
                <TextCell Text="Phone Number" Detail="{Binding Contact.ContactPhoneNumber}"/>
                <TextCell Text="Description" Detail="{Binding Contact.ContactDescription}"/>
            </TableSection>
        </TableRoot>
    </TableView>
</ContentPage>

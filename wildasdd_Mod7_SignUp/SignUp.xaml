<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="wildasdd_Mod7_SignUp.SignUp">
    <ScrollView>
        <VerticalStackLayout
        Padding="30,0"
        Spacing="50">
            <Entry x:Name="Username" Placeholder="Username"/>
            <Entry x:Name="Email" Placeholder="Email"/>
            <Entry x:Name="Password" IsPassword="True" Placeholder="Password"/>
            <Entry x:Name="ConfirmPassword" IsPassword="True" Placeholder="Confirm Password"/>
            <Button
            x:Name="SignUpButton"
            Text="Sign Up"
            Clicked="SignUpClicked"
            HorizontalOptions="Center"
            BackgroundColor="Blue"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
